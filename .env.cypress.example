# Cypress environment variable template
# ----------------------------------------
# Copy this file to cypress.env.json and fill in the real values.
# cypress.env.json is git-ignored and should never be committed.
#
# Alternatively, set the variables as CI environment variables prefixed with
# CYPRESS_ (e.g. CYPRESS_WP_USERNAME=admin).

{
    "WP_USERNAME": "admin",
    "WP_PASSWORD": "password"
}
