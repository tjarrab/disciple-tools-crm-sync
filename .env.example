# Cypress E2E test environment variables
#
# Copy this file to .env and fill in the values for your local environment.
# .env is git-ignored and should never be committed.
#
# Alternatively, these can be set directly as OS environment variables
# (prefixed with CYPRESS_) or via cypress.env.json (also git-ignored).
#
# See: https://docs.cypress.io/guides/guides/environment-variables

# Base URL of the WordPress instance under test.
# Must include the protocol and port (if non-standard).
CYPRESS_BASE_URL=http://localhost:8080

# WordPress admin credentials used by cy.dtLogin().
CYPRESS_WP_USERNAME=admin
CYPRESS_WP_PASSWORD=password

# Set to "true" in CI to enable Cypress video recording.
CYPRESS_VIDEO=false
